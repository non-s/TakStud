package com.example.takstud.ui

import android.util.Log
import com.example.takstud.model.Role
import com.example.takstud.model.Student
import com.example.takstud.model.UserSession
import com.example.takstud.security.AccessValidator
import com.example.takstud.util.SessionManager
import io.mockk.every
import io.mockk.mockk
import io.mockk.verify
import org.junit.Before
import org.junit.Test
import kotlin.test.assertFalse
import kotlin.test.assertTrue

/**
 * Testes de integração para AuthGuardExtended.
 *
 * Valida:
 * - Validação parent-student em composables
 * - Validação teacher-class em composables
 * - Logging de auditoria
 * - Fallback routes quando acesso negado
 */
class AuthGuardExtendedTest {

    private lateinit var sessionManager: SessionManager
    private val parentId = "parent_001"
    private val studentId = "student_001"
    private val studentId2 = "student_002"
    private val teacherId = "teacher_001"
    private val adminId = "admin_001"

    @Before
    fun setUp() {
        sessionManager = mockk()
        // Limpar audit logs antes de cada teste
        AccessValidator.clearOldAuditLogs(0)
    }

    // ==================== PARENT ACCESS GUARD TESTS ====================

    @Test
    fun `parent can access their own student`() {
        // Arrange
        val session = UserSession(
            userId = parentId,
            role = Role.PARENT.name,
            token = "token_123"
        )
        every { sessionManager.getActiveSession() } returns session

        val parentStudentRel = AccessValidator.ParentStudentRelationship(
            parentId = parentId,
            studentIds = listOf(studentId, studentId2)
        )

        // Act
        val canAccess = AccessValidator.canParentAccessStudent(
            currentParentId = parentId,
            studentId = studentId,
            student = Student(id = studentId, ra = "001", name = "João", studentClass = "6A"),
            relationship = parentStudentRel
        )

        // Assert
        assertTrue(canAccess, "Parent deveria conseguir acessar seu próprio estudante")
    }

    @Test
    fun `parent cannot access another parent's student`() {
        // Arrange
        val session = UserSession(
            userId = "parent_002",  // Parent diferente
            role = Role.PARENT.name,
            token = "token_123"
        )
        every { sessionManager.getActiveSession() } returns session

        val parentStudentRel = AccessValidator.ParentStudentRelationship(
            parentId = parentId,  // Rel pertence a parent_001
            studentIds = listOf(studentId)
        )

        // Act
        val canAccess = AccessValidator.canParentAccessStudent(
            currentParentId = "parent_002",
            studentId = studentId,
            student = Student(id = studentId, ra = "001", name = "João", studentClass = "6A"),
            relationship = parentStudentRel
        )

        // Assert
        assertFalse(canAccess, "Parent NÃO deveria conseguir acessar estudante de outro parent")
    }

    @Test
    fun `parent without session cannot access any student`() {
        // Arrange
        val session = UserSession(
            userId = "",  // Sem user ID
            role = Role.PARENT.name,
            token = ""
        )
        every { sessionManager.getActiveSession() } returns session

        val parentStudentRel = AccessValidator.ParentStudentRelationship(
            parentId = parentId,
            studentIds = listOf(studentId)
        )

        // Act
        val canAccess = AccessValidator.canParentAccessStudent(
            currentParentId = "",
            studentId = studentId,
            student = Student(id = studentId, ra = "001", name = "João", studentClass = "6A"),
            relationship = parentStudentRel
        )

        // Assert
        assertFalse(canAccess, "Parent sem session NÃO deveria conseguir acessar")
    }

    // ==================== TEACHER ACCESS GUARD TESTS ====================

    @Test
    fun `teacher can access their own class`() {
        // Arrange
        val session = UserSession(
            userId = teacherId,
            role = Role.TEACHER.name,
            token = "token_123"
        )
        every { sessionManager.getActiveSession() } returns session

        val teacherClassRel = AccessValidator.TeacherClassRelationship(
            teacherId = teacherId,
            classNames = listOf("6A", "6B", "7A")
        )

        // Act
        val canAccess = AccessValidator.canTeacherAccessClass(
            currentTeacherId = teacherId,
            className = "6A",
            relationship = teacherClassRel
        )

        // Assert
        assertTrue(canAccess, "Teacher deveria conseguir acessar sua turma")
    }

    @Test
    fun `teacher cannot access class they don't teach`() {
        // Arrange
        val session = UserSession(
            userId = teacherId,
            role = Role.TEACHER.name,
            token = "token_123"
        )
        every { sessionManager.getActiveSession() } returns session

        val teacherClassRel = AccessValidator.TeacherClassRelationship(
            teacherId = teacherId,
            classNames = listOf("6A", "6B")
        )

        // Act
        val canAccess = AccessValidator.canTeacherAccessClass(
            currentTeacherId = teacherId,
            className = "7A",  // Não leciona
            relationship = teacherClassRel
        )

        // Assert
        assertFalse(canAccess, "Teacher NÃO deveria acessar turma que não leciona")
    }

    @Test
    fun `different teachers cannot access each other's classes`() {
        // Arrange
        val teacher2 = "teacher_002"
        val session = UserSession(
            userId = teacher2,
            role = Role.TEACHER.name,
            token = "token_456"
        )
        every { sessionManager.getActiveSession() } returns session

        val teacherClassRel = AccessValidator.TeacherClassRelationship(
            teacherId = teacherId,  // Teacher 1
            classNames = listOf("6A", "6B")
        )

        // Act
        val canAccess = AccessValidator.canTeacherAccessClass(
            currentTeacherId = teacher2,  // Teacher 2 tentando acessar
            className = "6A",
            relationship = teacherClassRel
        )

        // Assert
        assertFalse(canAccess, "Teacher 2 NÃO deveria acessar turma de Teacher 1")
    }

    // ==================== TEACHER-STUDENT ACCESS TESTS ====================

    @Test
    fun `teacher can access students of their class`() {
        // Arrange
        val session = UserSession(
            userId = teacherId,
            role = Role.TEACHER.name,
            token = "token_123"
        )
        every { sessionManager.getActiveSession() } returns session

        val student = Student(id = studentId, ra = "001", name = "João", studentClass = "6A")
        val teacherClasses = listOf("6A", "6B")

        // Act
        val canAccess = AccessValidator.getAccessibleStudentsForTeacher(
            currentTeacherId = teacherId,
            allStudents = listOf(student),
            teacherClasses = teacherClasses
        ).isNotEmpty()

        // Assert
        assertTrue(canAccess, "Teacher deveria conseguir acessar alunos da sua turma")
    }

    @Test
    fun `teacher cannot access students of classes they don't teach`() {
        // Arrange
        val session = UserSession(
            userId = teacherId,
            role = Role.TEACHER.name,
            token = "token_123"
        )
        every { sessionManager.getActiveSession() } returns session

        val student = Student(id = studentId, ra = "001", name = "João", studentClass = "7A")
        val teacherClasses = listOf("6A", "6B")  // Não leciona 7A

        // Act
        val accessibleStudents = AccessValidator.getAccessibleStudentsForTeacher(
            currentTeacherId = teacherId,
            allStudents = listOf(student),
            teacherClasses = teacherClasses
        )

        // Assert
        assertTrue(accessibleStudents.isEmpty(), "Teacher NÃO deveria ver alunos de turma que não leciona")
    }

    // ==================== AUDIT LOGGING TESTS ====================

    @Test
    fun `successful parent access is logged`() {
        // Arrange
        AccessValidator.logAccessAttempt(
            userId = parentId,
            userRole = Role.PARENT.name,
            resourceType = "STUDENT",
            resourceId = studentId,
            granted = true
        )

        // Act
        val logs = AccessValidator.getAuditLogs(userId = parentId, grantedOnly = true)

        // Assert
        assertTrue(logs.isNotEmpty(), "Acesso concedido deveria ser registrado")
        assertTrue(logs[0].granted, "Log deveria indicar acesso concedido")
    }

    @Test
    fun `denied access is logged`() {
        // Arrange
        AccessValidator.logAccessAttempt(
            userId = parentId,
            userRole = Role.PARENT.name,
            resourceType = "STUDENT",
            resourceId = studentId,
            granted = false
        )

        // Act
        val logs = AccessValidator.getAuditLogs(userId = parentId, deniedOnly = true)

        // Assert
        assertTrue(logs.isNotEmpty(), "Acesso negado deveria ser registrado")
        assertFalse(logs[0].granted, "Log deveria indicar acesso negado")
    }

    @Test
    fun `audit logs contain correct metadata`() {
        // Arrange
        AccessValidator.logAccessAttempt(
            userId = parentId,
            userRole = Role.PARENT.name,
            resourceType = "STUDENT",
            resourceId = studentId,
            granted = true
        )

        // Act
        val logs = AccessValidator.getAuditLogs(userId = parentId)

        // Assert
        assertTrue(logs.isNotEmpty())
        val log = logs[0]
        assertTrue(log.userId == parentId)
        assertTrue(log.userRole == Role.PARENT.name)
        assertTrue(log.resourceType == "STUDENT")
        assertTrue(log.resourceId == studentId)
        assertTrue(log.granted)
        assertTrue(log.timestamp > 0)
    }

    // ==================== ADMIN ACCESS TESTS ====================

    @Test
    fun `admin can access any student`() {
        // Arrange
        val session = UserSession(
            userId = adminId,
            role = Role.ADMIN.name,
            token = "token_789"
        )
        every { sessionManager.getActiveSession() } returns session

        // Act
        val canAccess = AccessValidator.canAdminAccessAnything(adminId)

        // Assert
        assertTrue(canAccess, "Admin deveria conseguir acessar qualquer coisa")
    }

    @Test
    fun `admin can access any class`() {
        // Arrange
        val session = UserSession(
            userId = adminId,
            role = Role.ADMIN.name,
            token = "token_789"
        )
        every { sessionManager.getActiveSession() } returns session

        // Act
        val canAccess = AccessValidator.canAdminAccessAnything(adminId)

        // Assert
        assertTrue(canAccess, "Admin deveria conseguir acessar qualquer turma")
    }

    // ==================== REALISTIC SCENARIO TESTS ====================

    @Test
    fun `scenario - multiple parents with multiple students`() {
        // Arrange
        val parent1 = "parent_001"
        val parent2 = "parent_002"
        val student1 = "student_001"
        val student2 = "student_002"
        val student3 = "student_003"

        val rel1 = AccessValidator.ParentStudentRelationship(
            parentId = parent1,
            studentIds = listOf(student1, student2)
        )

        val rel2 = AccessValidator.ParentStudentRelationship(
            parentId = parent2,
            studentIds = listOf(student3)
        )

        // Act & Assert - Parent 1 consegue acessar seu próprio
        assertTrue(
            AccessValidator.canParentAccessStudent(parent1, student1, mockk(), rel1)
        )

        // Parent 1 consegue acessar outro seu
        assertTrue(
            AccessValidator.canParentAccessStudent(parent1, student2, mockk(), rel1)
        )

        // Parent 1 NÃO consegue acessar de Parent 2
        assertFalse(
            AccessValidator.canParentAccessStudent(parent1, student3, mockk(), rel1)
        )

        // Parent 2 consegue acessar o seu
        assertTrue(
            AccessValidator.canParentAccessStudent(parent2, student3, mockk(), rel2)
        )

        // Parent 2 NÃO consegue acessar de Parent 1
        assertFalse(
            AccessValidator.canParentAccessStudent(parent2, student1, mockk(), rel2)
        )
    }

    @Test
    fun `scenario - multiple teachers with overlapping classes`() {
        // Arrange
        val teacher1 = "teacher_001"
        val teacher2 = "teacher_002"

        val rel1 = AccessValidator.TeacherClassRelationship(
            teacherId = teacher1,
            classNames = listOf("6A", "7A")
        )

        val rel2 = AccessValidator.TeacherClassRelationship(
            teacherId = teacher2,
            classNames = listOf("7A", "8A")  // 7A compartilhada
        )

        // Act & Assert
        assertTrue(AccessValidator.canTeacherAccessClass(teacher1, "6A", rel1))
        assertTrue(AccessValidator.canTeacherAccessClass(teacher1, "7A", rel1))
        assertFalse(AccessValidator.canTeacherAccessClass(teacher1, "8A", rel1))

        assertFalse(AccessValidator.canTeacherAccessClass(teacher2, "6A", rel2))
        assertTrue(AccessValidator.canTeacherAccessClass(teacher2, "7A", rel2))
        assertTrue(AccessValidator.canTeacherAccessClass(teacher2, "8A", rel2))
    }

    @Test
    fun `scenario - session validation before data access`() {
        // Arrange
        val validSession = UserSession(
            userId = parentId,
            role = Role.PARENT.name,
            token = "valid_token"
        )

        val invalidSession = UserSession(
            userId = "",
            role = Role.PARENT.name,
            token = ""
        )

        // Act
        val validCanAccess = AccessValidator.canParentAccessStudent(
            parentId,
            studentId,
            Student(id = studentId, ra = "001", name = "João", studentClass = "6A"),
            AccessValidator.ParentStudentRelationship(parentId, listOf(studentId))
        )

        val invalidCanAccess = AccessValidator.canParentAccessStudent(
            "",
            studentId,
            Student(id = studentId, ra = "001", name = "João", studentClass = "6A"),
            AccessValidator.ParentStudentRelationship(parentId, listOf(studentId))
        )

        // Assert
        assertTrue(validCanAccess, "Sessão válida deveria permitir acesso")
        assertFalse(invalidCanAccess, "Sessão inválida deveria negar acesso")
    }
}
