rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // FUNÇÕES AUXILIARES
    // ============================================
    
    // Verifica se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Verifica se o usuário é um professor
    function isTeacher() {
      return isAuthenticated() && 
             request.auth.token.role == 'teacher';
    }
    
    // Verifica se é o próprio usuário
    function isOwner(userId) {
      return isAuthenticated() && 
             request.auth.uid == userId;
    }
    
    // Verifica se é o criador do documento
    function isCreator() {
      return isAuthenticated() && 
             resource.data.createdBy == request.auth.uid;
    }
    
    // ============================================
    // REGRAS DAS COLLECTIONS
    // ============================================
    
    // USERS - Apenas professores
    match /users/{userId} {
      // Qualquer usuário autenticado pode ler
      allow read: if isAuthenticated();
      
      // Apenas o próprio usuário pode editar seus dados
      allow write: if isOwner(userId);
      
      // Apenas professores podem criar novos usuários
      allow create: if isTeacher();
    }
    
    // SCHEDULES - Horários de aula
    match /schedules/{scheduleId} {
      // Qualquer usuário autenticado pode ler horários
      allow read: if isAuthenticated();
      
      // Apenas professores podem criar/editar/deletar horários
      allow create, update, delete: if isTeacher();
    }
    
    // NOTICES - Avisos
    match /notices/{noticeId} {
      // Qualquer usuário autenticado pode ler avisos
      allow read: if isAuthenticated();
      
      // Apenas professores podem criar avisos
      allow create: if isTeacher();
      
      // Apenas o criador pode editar/deletar seus próprios avisos
      allow update, delete: if isTeacher() && isCreator();
    }
    
    // TASKS - Atividades/Tarefas
    match /tasks/{taskId} {
      // Qualquer usuário autenticado pode ler tarefas
      allow read: if isAuthenticated();
      
      // Apenas professores podem criar tarefas
      allow create: if isTeacher();
      
      // Apenas o criador pode editar/deletar suas próprias tarefas
      allow update, delete: if isTeacher() && isCreator();
    }
    
    // ============================================
    // BLOQUEAR ACESSO A OUTRAS COLLECTIONS
    // ============================================
    
    // Bloquear acesso a qualquer outra collection não especificada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
