/**
 * FIRESTORE SECURITY RULES - TakStud
 *
 * IMPORTANTE: O app usa autenticação customizada (sem Firebase Auth),
 * portanto não temos request.auth disponível. As regras protegem o que
 * é possível proteger nesse modelo:
 *
 * - config/teacherAccess: leitura permitida (necessária para login),
 *                          escrita bloqueada (só via Console Firebase)
 * - fcm_tokens: escrita permitida (dispositivos registram tokens),
 *               leitura bloqueada (tokens são privados)
 * - notifications: escrita e leitura permitidas (app gerencia)
 * - students: leitura permitida (login por RA), escrita pelo app
 * - Demais coleções: leitura/escrita permitidas para o app funcionar
 *
 * NOTA: Para segurança completa, migrar para Firebase Authentication
 * (Anonymous + Custom Token) em versão futura.
 *
 * Versão: 2.0 — compatível com autenticação customizada
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== CONFIG (professor) ====================
    // Leitura permitida: o app precisa verificar o código do professor
    // Escrita BLOQUEADA: código só pode ser alterado via Console Firebase
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ==================== FCM TOKENS ====================
    // Dispositivos gravam seus próprios tokens (push notifications)
    // Leitura bloqueada: tokens são sensíveis e só o backend usa
    match /fcm_tokens/{deviceId} {
      allow create, update: if true;
      allow read, delete: if false;
    }

    // ==================== NOTIFICATIONS ====================
    // Leitura e escrita: app gerencia notificações dos usuários
    // Proteção futura: migrar para Firebase Auth com query por uid
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // ==================== NOTIFICATION SETTINGS ====================
    match /notificationSettings/{userId} {
      allow read, write: if true;
    }

    // ==================== STUDENTS ====================
    // Leitura: necessária para login por RA
    // Escrita: professores criam/atualizam alunos pelo app
    match /students/{studentId} {
      allow read, write: if true;
    }

    // ==================== TASKS ====================
    match /tasks/{taskId} {
      allow read, write: if true;
    }

    // ==================== NOTICES ====================
    match /notices/{noticeId} {
      allow read, write: if true;
    }

    // ==================== SCHEDULES ====================
    match /schedules/{scheduleId} {
      allow read, write: if true;
    }

    // ==================== EVENTS (calendar) ====================
    match /events/{eventId} {
      allow read, write: if true;
    }

    // ==================== CLASSES ====================
    match /classes/{classId} {
      allow read, write: if true;
    }

    // ==================== AUDIT LOGS (append-only) ====================
    match /auditLogs/{logId} {
      allow create: if true;
      allow read: if false;
      allow update, delete: if false;
    }

    // ==================== CATCH-ALL ====================
    // Tudo que não foi explicitamente permitido acima é bloqueado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
