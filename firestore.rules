rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // config: leitura para login do professor, escrita bloqueada (somente Console)
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // fcm_tokens: dispositivos registram token, leitura bloqueada externamente
    match /fcm_tokens/{deviceId} {
      allow create, update: if request.resource.data.keys().hasAll(['token', 'updatedAt'])
                           && request.resource.data.token is string
                           && request.resource.data.token.size() > 0;
      allow read, delete: if false;
    }

    // notifications: escrita exige campos obrigatórios
    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['title', 'body', 'createdAt'])
                   && request.resource.data.title is string
                   && request.resource.data.body is string;
      allow update, delete: if true;
    }

    match /notificationSettings/{userId} {
      allow read, write: if true;
    }

    // students: criação exige campos mínimos
    match /students/{studentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'ra', 'classId'])
                   && request.resource.data.name is string
                   && request.resource.data.ra is string;
      allow update, delete: if true;
    }

    // tasks: título obrigatório e limitado a 200 chars
    match /tasks/{taskId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['title', 'dueDate', 'classId'])
                   && request.resource.data.title is string
                   && request.resource.data.title.size() > 0
                   && request.resource.data.title.size() <= 200;
      allow update, delete: if true;
    }

    // notices: título obrigatório
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['title', 'content', 'createdAt'])
                   && request.resource.data.title is string
                   && request.resource.data.title.size() > 0;
      allow update, delete: if true;
    }

    match /schedules/{scheduleId} {
      allow read, write: if true;
    }

    match /events/{eventId} {
      allow read, write: if true;
    }

    match /classes/{classId} {
      allow read, write: if true;
    }

    // auditLogs: append-only, sem leitura/update/delete pelo app
    match /auditLogs/{logId} {
      allow create: if request.resource.data.keys().hasAll(['action', 'timestamp'])
                   && request.resource.data.action is string;
      allow read, update, delete: if false;
    }

    // bloqueia todo acesso não listado acima
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
